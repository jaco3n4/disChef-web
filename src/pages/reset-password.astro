---
// Reset Password — Split Panel Design
// Firebase logic preserved, design inspired by modern split layout
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Réinitialiser votre mot de passe | DisChef</title>
  <meta name="description" content="Réinitialisation de votre mot de passe DisChef." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/png" href="/images/dischef-logo.png" />
  <meta name="theme-color" content="#f97316" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --orange: #f97316;
      --orange-hover: #ea580c;
      --orange-light: #fb923c;
      --orange-glow: rgba(249, 115, 22, 0.3);
      --slate-50: #f8fafc;
      --slate-100: #f1f5f9;
      --slate-200: #e2e8f0;
      --slate-300: #cbd5e1;
      --slate-400: #94a3b8;
      --slate-500: #64748b;
      --slate-600: #475569;
      --slate-700: #334155;
      --slate-800: #1e293b;
      --slate-900: #0f172a;
      --success: #10b981;
      --error: #ef4444;
    }

    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

    body {
      min-height: 100dvh;
      display: flex;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--slate-800);
      background: #ffffff;
    }

    /* =============================================
       LEFT PANEL — Branding
       ============================================= */
    .panel-left {
      display: none;
      width: 42%;
      background: var(--slate-900);
      position: relative;
      flex-direction: column;
      justify-content: space-between;
      padding: 48px;
      overflow: hidden;
    }

    /* Glows */
    .glow-1 {
      position: absolute;
      top: -20%;
      left: -20%;
      width: 70%;
      height: 70%;
      border-radius: 50%;
      background: var(--orange);
      filter: blur(120px);
      opacity: 0.25;
      pointer-events: none;
    }

    .glow-2 {
      position: absolute;
      bottom: -10%;
      right: -10%;
      width: 60%;
      height: 60%;
      border-radius: 50%;
      background: var(--slate-400);
      filter: blur(100px);
      opacity: 0.08;
      pointer-events: none;
    }

    /* Brand top */
    .brand-top {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand-top img {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      box-shadow: 0 8px 24px rgba(249, 115, 22, 0.25);
    }

    .brand-top span {
      color: #ffffff;
      font-size: 1.25rem;
      font-weight: 900;
      letter-spacing: -0.02em;
    }

    /* Quote block */
    .quote-block {
      position: relative;
      z-index: 1;
      margin-bottom: 48px;
    }

    .quote-icon {
      color: var(--orange);
      opacity: 0.5;
      margin-bottom: 24px;
    }

    .quote-block h2 {
      font-size: 2.5rem;
      font-weight: 800;
      color: #ffffff;
      line-height: 1.15;
      letter-spacing: -0.03em;
      margin-bottom: 20px;
    }

    .text-gradient {
      background: linear-gradient(135deg, var(--orange), var(--orange-light));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .quote-block p {
      color: var(--slate-300);
      font-size: 1.125rem;
      max-width: 380px;
      line-height: 1.7;
    }

    /* Footer left */
    .panel-left-footer {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--slate-400);
      font-size: 0.875rem;
      font-weight: 500;
    }

    .panel-left-footer svg { color: var(--orange); }

    /* =============================================
       RIGHT PANEL — Form
       ============================================= */
    .panel-right {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      position: relative;
    }

    .form-container {
      width: 100%;
      max-width: 440px;
      animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Mobile brand */
    .mobile-brand {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 40px;
    }

    .mobile-brand img {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      box-shadow: 0 4px 16px rgba(249, 115, 22, 0.2);
    }

    .mobile-brand span {
      font-size: 1.25rem;
      font-weight: 900;
      color: var(--slate-900);
      letter-spacing: -0.02em;
    }

    /* Header text */
    .form-header {
      margin-bottom: 40px;
    }

    .form-header h1 {
      font-size: 1.875rem;
      font-weight: 800;
      color: var(--slate-900);
      letter-spacing: -0.03em;
      margin-bottom: 10px;
      line-height: 1.2;
    }

    .form-header p {
      font-size: 1rem;
      color: var(--slate-500);
      line-height: 1.6;
    }

    /* --- Form Fields --- */
    .form-fields { display: flex; flex-direction: column; gap: 24px; }

    .field-group label {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
    }

    .field-group label span {
      font-size: 0.875rem;
      font-weight: 700;
      color: var(--slate-700);
    }

    .input-box {
      position: relative;
    }

    .input-icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--slate-400);
      pointer-events: none;
      transition: color 0.25s ease;
    }

    .input-box:focus-within .input-icon {
      color: var(--orange);
    }

    .input-box input {
      width: 100%;
      background: var(--slate-50);
      border: 1.5px solid var(--slate-200);
      border-radius: 16px;
      padding: 16px 52px 16px 48px;
      font-size: 1rem;
      font-family: inherit;
      font-weight: 500;
      color: var(--slate-900);
      transition: all 0.25s ease;
    }

    .input-box input:hover {
      border-color: var(--slate-300);
    }

    .input-box input:focus {
      outline: none;
      border-color: var(--orange);
      background: #ffffff;
      box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.08);
    }

    .input-box input::placeholder {
      color: var(--slate-400);
      font-weight: 400;
    }

    .input-box input.input-valid { border-color: var(--success); }
    .input-box input.input-valid:focus { box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.08); }
    .input-box input.input-invalid { border-color: var(--error); }
    .input-box input.input-invalid:focus { box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.08); }

    /* Toggle eye */
    .toggle-eye {
      position: absolute;
      right: 4px;
      top: 50%;
      transform: translateY(-50%);
      width: 44px;
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--slate-400);
      border-radius: 12px;
      transition: color 0.2s, background 0.2s;
      padding: 0;
    }

    .toggle-eye:hover { color: var(--slate-600); background: var(--slate-100); }
    .toggle-eye:active { transform: translateY(-50%) scale(0.92); }
    .toggle-eye:focus-visible { outline: 2px solid var(--orange); outline-offset: -2px; }

    /* Password strength */
    .pw-strength {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 10px;
      height: 20px;
      opacity: 0;
      transform: translateY(-4px);
      transition: opacity 0.3s, transform 0.3s;
    }

    .pw-strength.visible { opacity: 1; transform: translateY(0); }

    .str-bars { display: flex; gap: 4px; }

    .str-bar {
      width: 40px;
      height: 4px;
      border-radius: 4px;
      background: var(--slate-200);
      transition: background-color 0.3s, transform 0.2s;
    }

    .str-bar.active { transform: scaleY(1.4); }
    .str-bar.s-weak { background: var(--error); }
    .str-bar.s-fair { background: #f59e0b; }
    .str-bar.s-good { background: #34d399; }
    .str-bar.s-strong { background: var(--success); }

    .str-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--slate-400);
      white-space: nowrap;
      transition: color 0.3s;
    }

    .str-label.t-weak { color: var(--error); }
    .str-label.t-fair { color: #f59e0b; }
    .str-label.t-good { color: #34d399; }
    .str-label.t-strong { color: var(--success); }

    /* Match indicator */
    .match-ind {
      margin-top: 12px;
      font-size: 0.8125rem;
      font-weight: 600;
      min-height: 20px;
      display: flex;
      align-items: center;
      gap: 6px;
      opacity: 0;
      transition: opacity 0.3s;
    }

    .match-ind.visible { opacity: 1; }
    .match-ind.match-ok { color: var(--success); }
    .match-ind.match-fail { color: var(--error); }

    /* Error message */
    .error-msg {
      color: var(--error);
      font-size: 0.875rem;
      font-weight: 600;
      text-align: center;
      padding: 12px 16px;
      background: #fef2f2;
      border-radius: 14px;
      border: 1px solid #fecaca;
      animation: shake 0.4s ease;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20% { transform: translateX(-6px); }
      40% { transform: translateX(6px); }
      60% { transform: translateX(-4px); }
      80% { transform: translateX(4px); }
    }

    /* Submit button */
    .submit-btn {
      width: 100%;
      margin-top: 32px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 1rem;
      font-weight: 700;
      font-family: inherit;
      border: none;
      cursor: pointer;
      border-radius: 16px;
      background: var(--orange);
      color: #ffffff;
      transition: all 0.25s ease;
      position: relative;
      overflow: hidden;
    }

    .submit-btn:hover:not(:disabled) {
      background: var(--orange-hover);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px var(--orange-glow);
    }

    .submit-btn:active:not(:disabled) {
      transform: translateY(0) scale(0.98);
    }

    .submit-btn:disabled {
      background: var(--slate-200);
      color: var(--slate-400);
      cursor: not-allowed;
      transform: none !important;
      box-shadow: none !important;
    }

    .submit-btn:focus-visible {
      outline: 2px solid var(--orange);
      outline-offset: 3px;
    }

    .submit-btn .arrow-icon {
      transition: transform 0.25s ease;
    }

    .submit-btn:hover:not(:disabled) .arrow-icon {
      transform: translateX(4px);
    }

    .submit-btn .spinner-btn {
      width: 22px;
      height: 22px;
      border: 2.5px solid rgba(255, 255, 255, 0.3);
      border-top-color: #ffffff;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* =============================================
       States — Success / Error / Loading
       ============================================= */
    .state-msg {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .state-msg h1 {
      font-size: 1.875rem;
      font-weight: 800;
      color: var(--slate-900);
      letter-spacing: -0.03em;
      margin-bottom: 4px;
    }

    .state-msg p {
      font-size: 1rem;
      color: var(--slate-500);
      line-height: 1.6;
    }

    .state-icon-box {
      width: 80px;
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 24px;
      margin-bottom: 20px;
      animation: iconPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    .state-icon-ok {
      background: #ecfdf5;
      box-shadow: inset 0 2px 8px rgba(16, 185, 129, 0.1);
    }
    .state-icon-ok svg { color: var(--success); }

    .state-icon-err {
      background: #fef2f2;
      box-shadow: inset 0 2px 8px rgba(239, 68, 68, 0.1);
    }
    .state-icon-err svg { color: var(--error); }

    @keyframes iconPop {
      0% { opacity: 0; transform: scale(0.4); }
      60% { transform: scale(1.1); }
      100% { opacity: 1; transform: scale(1); }
    }

    .state-action-btn {
      width: 100%;
      margin-top: 20px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-size: 1rem;
      font-weight: 700;
      font-family: inherit;
      border: none;
      cursor: pointer;
      border-radius: 16px;
      background: var(--slate-900);
      color: #ffffff;
      text-decoration: none;
      transition: all 0.25s ease;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.15);
    }

    .state-action-btn:hover {
      background: var(--slate-800);
      transform: translateY(-1px);
    }

    .state-action-btn:focus-visible {
      outline: 2px solid var(--orange);
      outline-offset: 3px;
    }

    /* Loading */
    .loading-block {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 20px;
      padding: 60px 0;
      animation: fadeUp 0.4s ease forwards;
    }

    .spinner-lg {
      width: 48px;
      height: 48px;
      border: 3px solid var(--slate-100);
      border-top-color: var(--orange);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    .loading-block p {
      font-size: 0.9375rem;
      color: var(--slate-500);
      font-weight: 500;
    }

    /* Footer secure */
    .secure-footer {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-top: 40px;
      color: var(--slate-400);
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.02em;
    }

    /* =============================================
       Responsive
       ============================================= */
    @media (min-width: 1024px) {
      .panel-left { display: flex; }
      .mobile-brand { display: none; }
      .panel-right { width: 58%; }
    }

    @media (max-width: 480px) {
      .panel-right { padding: 20px; }
      .form-header h1 { font-size: 1.5rem; }
      .mobile-brand { margin-bottom: 32px; }
      .input-box input { padding: 14px 48px 14px 44px; border-radius: 14px; }
      .submit-btn, .state-action-btn { height: 52px; border-radius: 14px; }
      .str-bar { width: 28px; }
    }

    /* =============================================
       Accessibility
       ============================================= */
    @media (prefers-reduced-motion: reduce) {
      .form-container, .state-msg, .loading-block, .state-icon-box {
        animation: none !important;
        opacity: 1;
        transform: none;
      }
      .str-bar, .pw-strength, .match-ind, .toggle-eye {
        transition: none !important;
      }
      .error-msg { animation: none !important; }
      .glow-1, .glow-2 { display: none; }
    }
  </style>
</head>
<body>

  <!-- ==========================================
       LEFT PANEL — Branding (desktop only)
       ========================================== -->
  <aside class="panel-left">
    <div class="glow-1" aria-hidden="true"></div>
    <div class="glow-2" aria-hidden="true"></div>

    <!-- Brand top -->
    <div class="brand-top">
      <img src="/images/dischef-logo.png" alt="DisChef" width="44" height="44" />
      <span>DisChef</span>
    </div>

    <!-- Quote -->
    <div class="quote-block">
      <!-- Quote icon -->
      <svg class="quote-icon" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C9.591 11.68 11 13.17 11 15c0 1.933-1.567 3.5-3.5 3.5-1.195 0-2.317-.59-2.917-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311C19.591 11.68 21 13.17 21 15c0 1.933-1.567 3.5-3.5 3.5-1.195 0-2.317-.59-2.917-1.179z"/>
      </svg>
      <h2>
        L'IA enfile<br/>
        <span class="text-gradient">son tablier.</span>
      </h2>
      <p>Générez des repas sur-mesure, découvrez de nouvelles saveurs et laissez Le Chef transformer vos ingrédients du quotidien en plats étoilés.</p>
    </div>

    <!-- Footer -->
    <div class="panel-left-footer">
      <!-- Sparkles icon -->
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3z"/>
      </svg>
      Propulsé par l'Intelligence Artificielle
    </div>
  </aside>

  <!-- ==========================================
       RIGHT PANEL — Form
       ========================================== -->
  <main class="panel-right">
    <div class="form-container">

      <!-- Mobile brand (hidden on desktop) -->
      <div class="mobile-brand">
        <img src="/images/dischef-logo.png" alt="DisChef" width="44" height="44" />
        <span>DisChef</span>
      </div>

      <!-- FORM STATE -->
      <div id="form-state">
        <div class="form-header">
          <h1>On repart du bon pied</h1>
          <p>Choisissez votre nouveau mot de passe et on se retrouve en cuisine.</p>
        </div>

        <form id="reset-form" novalidate>
          <div class="form-fields">
            <!-- Password -->
            <div class="field-group">
              <label>
                <span>Nouveau mot de passe</span>
              </label>
              <div class="input-box">
                <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <input
                  type="password"
                  id="password"
                  name="password"
                  placeholder="8 caractères minimum"
                  minlength="8"
                  required
                  autocomplete="new-password"
                  aria-describedby="pw-strength-text"
                />
                <button type="button" class="toggle-eye" data-target="password" aria-label="Afficher le mot de passe">
                  <svg class="icon-eye" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                  </svg>
                  <svg class="icon-eye-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                  </svg>
                </button>
              </div>
              <div class="pw-strength" id="pw-strength" aria-live="polite">
                <div class="str-bars">
                  <div class="str-bar" data-level="1"></div>
                  <div class="str-bar" data-level="2"></div>
                  <div class="str-bar" data-level="3"></div>
                  <div class="str-bar" data-level="4"></div>
                </div>
                <span class="str-label" id="pw-strength-text"></span>
              </div>
            </div>

            <!-- Confirm -->
            <div class="field-group">
              <label>
                <span>Confirmation</span>
              </label>
              <div class="input-box">
                <svg class="input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <path d="M9 12l2 2 4-4"/>
                </svg>
                <input
                  type="password"
                  id="password-confirm"
                  name="password-confirm"
                  placeholder="Saisissez-le à nouveau"
                  minlength="8"
                  required
                  autocomplete="new-password"
                  aria-describedby="match-indicator"
                />
                <button type="button" class="toggle-eye" data-target="password-confirm" aria-label="Afficher le mot de passe">
                  <svg class="icon-eye" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                  </svg>
                  <svg class="icon-eye-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                  </svg>
                </button>
              </div>
              <div class="match-ind" id="match-indicator" aria-live="polite"></div>
            </div>
          </div>

          <p id="error-message" class="error-msg" style="display: none;" role="alert"></p>

          <button type="submit" class="submit-btn" id="submit-btn" disabled>
            <span id="btn-text">Mettre à jour le mot de passe</span>
            <!-- Arrow -->
            <svg id="btn-arrow" class="arrow-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
            <div id="btn-spinner" class="spinner-btn" style="display:none;"></div>
          </button>
        </form>
      </div>

      <!-- SUCCESS STATE -->
      <div id="success-state" style="display: none;">
        <div class="state-msg">
          <div class="state-icon-box state-icon-ok">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h1>Mot de passe à jour !</h1>
          <p>Votre nouvelle clé a bien été enregistrée. Vous pouvez retourner aux fourneaux.</p>
          <a href="/" class="state-action-btn">
            Retourner à l'accueil
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <!-- ERROR STATE -->
      <div id="error-state" style="display: none;">
        <div class="state-msg">
          <div class="state-icon-box state-icon-err">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          </div>
          <h1>Oups, un pépin</h1>
          <p>Ce lien a peut-être expiré. Relancez la demande depuis l'app DisChef.</p>
          <a href="/" class="state-action-btn">
            Retourner à l'accueil
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>

      <!-- LOADING STATE -->
      <div id="loading-state" style="display: none;">
        <div class="loading-block">
          <div class="spinner-lg"></div>
          <p>Le Chef vérifie votre lien...</p>
        </div>
      </div>

      <!-- Secure footer -->
      <div class="secure-footer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Connexion sécurisée
      </div>
    </div>
  </main>

  <!-- ==========================================
       SCRIPTS — Firebase + UI
       ========================================== -->
  <script>
    import { initializeApp } from 'firebase/app';
    import { getAuth, confirmPasswordReset, verifyPasswordResetCode } from 'firebase/auth';

    const firebaseConfig = {
      apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
      authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
      projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    const urlParams = new URLSearchParams(window.location.search);
    const oobCode = urlParams.get('oobCode');
    const mode = urlParams.get('mode');

    const formState = document.getElementById('form-state')!;
    const successState = document.getElementById('success-state')!;
    const errorState = document.getElementById('error-state')!;
    const loadingState = document.getElementById('loading-state')!;
    const form = document.getElementById('reset-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-message')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text')!;
    const btnArrow = document.getElementById('btn-arrow')!;
    const btnSpinner = document.getElementById('btn-spinner')!;

    function showState(state: 'form' | 'success' | 'error' | 'loading') {
      formState.style.display = state === 'form' ? 'block' : 'none';
      successState.style.display = state === 'success' ? 'block' : 'none';
      errorState.style.display = state === 'error' ? 'block' : 'none';
      loadingState.style.display = state === 'loading' ? 'block' : 'none';
    }

    if (!oobCode || mode !== 'resetPassword') {
      showState('error');
    } else {
      showState('loading');
      verifyPasswordResetCode(auth, oobCode)
        .then(() => showState('form'))
        .catch(() => showState('error'));
    }

    // Smart submit button state
    const passwordInput = document.getElementById('password') as HTMLInputElement;
    const confirmInput = document.getElementById('password-confirm') as HTMLInputElement;

    function updateSubmitState() {
      const pw = passwordInput.value;
      const cf = confirmInput.value;
      submitBtn.disabled = pw.length < 8 || pw !== cf;
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const password = passwordInput.value;
      const confirm = confirmInput.value;

      errorMsg.style.display = 'none';

      if (password.length < 8) {
        errorMsg.textContent = '8 caractères minimum pour votre mot de passe.';
        errorMsg.style.display = 'block';
        return;
      }

      if (password !== confirm) {
        errorMsg.textContent = 'Les deux mots de passe ne correspondent pas.';
        errorMsg.style.display = 'block';
        return;
      }

      // Loading state on button
      submitBtn.disabled = true;
      btnText.textContent = 'Un instant...';
      btnArrow.style.display = 'none';
      btnSpinner.style.display = 'block';

      try {
        await confirmPasswordReset(auth, oobCode!, password);
        showState('success');
      } catch {
        errorMsg.textContent = 'Oups, ça n\'a pas fonctionné. Le lien a peut-être expiré.';
        errorMsg.style.display = 'block';
        submitBtn.disabled = false;
        btnText.textContent = 'Mettre à jour le mot de passe';
        btnArrow.style.display = 'block';
        btnSpinner.style.display = 'none';
      }
    });

    // ============================================
    // UI Enhancements
    // ============================================

    // Toggle password visibility
    document.querySelectorAll('.toggle-eye').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = (btn as HTMLElement).dataset.target!;
        const input = document.getElementById(targetId) as HTMLInputElement;
        const eyeIcon = btn.querySelector('.icon-eye') as SVGElement;
        const eyeOffIcon = btn.querySelector('.icon-eye-off') as SVGElement;

        if (input.type === 'password') {
          input.type = 'text';
          eyeIcon.style.display = 'none';
          eyeOffIcon.style.display = 'block';
          (btn as HTMLElement).setAttribute('aria-label', 'Masquer le mot de passe');
        } else {
          input.type = 'password';
          eyeIcon.style.display = 'block';
          eyeOffIcon.style.display = 'none';
          (btn as HTMLElement).setAttribute('aria-label', 'Afficher le mot de passe');
        }
      });
    });

    // Password strength
    const strengthContainer = document.getElementById('pw-strength')!;
    const strengthText = document.getElementById('pw-strength-text')!;
    const strengthBars = strengthContainer.querySelectorAll('.str-bar');

    function getPasswordStrength(pw: string): { level: number; label: string } {
      if (pw.length === 0) return { level: 0, label: '' };
      let score = 0;
      if (pw.length >= 8) score++;
      if (pw.length >= 12) score++;
      if (/[A-Z]/.test(pw) && /[a-z]/.test(pw)) score++;
      if (/\d/.test(pw)) score++;
      if (/[^A-Za-z0-9]/.test(pw)) score++;

      if (score <= 1) return { level: 1, label: 'Faible' };
      if (score === 2) return { level: 2, label: 'Moyen' };
      if (score === 3) return { level: 3, label: 'Bon' };
      return { level: 4, label: 'Excellent' };
    }

    const strClasses = ['', 's-weak', 's-fair', 's-good', 's-strong'];
    const txtClasses = ['', 't-weak', 't-fair', 't-good', 't-strong'];

    passwordInput?.addEventListener('input', () => {
      const val = passwordInput.value;
      const { level, label } = getPasswordStrength(val);

      strengthContainer.classList.toggle('visible', val.length > 0);

      strengthBars.forEach((bar, i) => {
        bar.classList.remove('active', 's-weak', 's-fair', 's-good', 's-strong');
        if (i < level) bar.classList.add('active', strClasses[level]);
      });

      strengthText.textContent = label;
      strengthText.className = 'str-label';
      if (level > 0) strengthText.classList.add(txtClasses[level]);

      updateMatchIndicator();
      updateSubmitState();
    });

    // Password match
    const matchIndicator = document.getElementById('match-indicator')!;

    function updateMatchIndicator() {
      const pw = passwordInput.value;
      const cf = confirmInput.value;

      if (cf.length === 0) {
        matchIndicator.classList.remove('visible', 'match-ok', 'match-fail');
        matchIndicator.innerHTML = '';
        confirmInput.classList.remove('input-valid', 'input-invalid');
        return;
      }

      matchIndicator.classList.add('visible');

      if (pw === cf) {
        matchIndicator.classList.remove('match-fail');
        matchIndicator.classList.add('match-ok');
        matchIndicator.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Mots de passe identiques';
        confirmInput.classList.remove('input-invalid');
        confirmInput.classList.add('input-valid');
      } else {
        matchIndicator.classList.remove('match-ok');
        matchIndicator.classList.add('match-fail');
        matchIndicator.innerHTML = 'Les mots de passe ne correspondent pas.';
        confirmInput.classList.remove('input-valid');
        confirmInput.classList.add('input-invalid');
      }
    }

    confirmInput?.addEventListener('input', () => {
      updateMatchIndicator();
      updateSubmitState();
    });
  </script>
</body>
</html>
