---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Mentions légales"
  description="Mentions légales du site DisChef.fr"
>
  <Header slot="header" />

  <div class="legal-page">
    <div class="container">
      <h1>Mentions légales</h1>
      <p class="legal-update">Dernière mise à jour : Mars 2026</p>

      <div class="legal-content">
        <section>
          <h2>Éditeur du site</h2>
          <p>
            Le site dischef.fr est édité par :<br />
            <em>[À compléter — Nom de la société ou du responsable]</em><br />
            <em>[Adresse]</em><br />
            Email : <a href="mailto:contact@dischef.fr">contact@dischef.fr</a>
          </p>
        </section>

        <section>
          <h2>Hébergement</h2>
          <p>
            Ce site est hébergé par Cloudflare, Inc.<br />
            101 Townsend St, San Francisco, CA 94107, USA<br />
            Site web : cloudflare.com
          </p>
        </section>

        <section>
          <h2>Propriété intellectuelle</h2>
          <p>
            L'ensemble du contenu du site dischef.fr (textes, images, logo, design)
            est protégé par le droit d'auteur. Toute reproduction, même partielle,
            est interdite sans autorisation préalable.
          </p>
        </section>

        <section>
          <h2>Données personnelles</h2>
          <p>
            Pour toute question relative à vos données personnelles, consultez notre
            <a href="/confidentialite">politique de confidentialité</a>.
          </p>
        </section>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .legal-page {
    padding-top: calc(var(--header-height) + 48px);
    padding-bottom: 80px;
  }

  .legal-page h1 {
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .legal-update {
    font-size: 0.875rem;
    color: var(--slate-400);
    margin-bottom: 48px;
  }

  .legal-content {
    max-width: 720px;
  }

  .legal-content section {
    margin-bottom: 40px;
  }

  .legal-content h2 {
    font-size: 1.25rem;
    margin-bottom: 12px;
  }

  .legal-content p {
    font-size: 1rem;
    line-height: 1.7;
  }

  .legal-content a {
    color: var(--frigo-500);
    text-decoration: underline;
  }

  .legal-content a:hover {
    color: var(--frigo-600);
  }

  .legal-content em {
    color: var(--slate-400);
  }
</style>
