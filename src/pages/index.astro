---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import HowItWorks from '../components/HowItWorks.astro';
import AntiGaspi from '../components/AntiGaspi.astro';
import LeChef from '../components/LeChef.astro';
import Download from '../components/Download.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="DisChef — Votre frigo a du talent"
  description="DisChef analyse votre frigo et compose des recettes anti-gaspi sur mesure grâce à l'IA. Scannez, parlez, cuisinez. Gratuit."
>
  <Header slot="header" />
  <Hero />
  <Features />
  <HowItWorks />
  <AntiGaspi />
  <LeChef />
  <Download />
  <Footer slot="footer" />
</BaseLayout>
