---
const features = [
  {
    icon: '📸',
    title: 'Scannez votre frigo',
    description: 'Prenez une photo de vos ingrédients ou ajoutez-les vocalement. Le Chef sait ce que vous avez.',
    color: 'orange',
  },
  {
    icon: '🧑‍🍳',
    title: '3 recettes sur mesure',
    description: 'Le Chef vous propose La Débrouille (100% votre frigo), Le Coup de Cœur et L\'Aventure.',
    color: 'blue',
  },
  {
    icon: '📅',
    title: 'Planning de la semaine',
    description: 'Composez 14 repas en un clic. Le Chef s\'adapte a vos gouts, votre budget et votre temps.',
    color: 'purple',
  },
  {
    icon: '🛒',
    title: 'Liste de courses intelligente',
    description: 'Générée automatiquement, classée par rayon. Partagez-la et rangez vos courses dans le frigo.',
    color: 'green',
  },
  {
    icon: '🎙️',
    title: 'Mains sales ? Parlez.',
    description: 'DisChef est conçu pour la cuisine. Les mains dans la pâte, utilisez votre voix.',
    color: 'rose',
  },
  {
    icon: '♻️',
    title: 'Zéro gaspillage',
    description: 'Le Chef priorise les produits qui vont périmer. Chaque ingrédient mérite d\'être cuisiné.',
    color: 'emerald',
  },
];

const colorMap: Record<string, { bg: string; border: string }> = {
  orange: { bg: '#fff7ed', border: '#fed7aa' },
  blue: { bg: '#eff6ff', border: '#bfdbfe' },
  purple: { bg: '#faf5ff', border: '#e9d5ff' },
  green: { bg: '#f0fdf4', border: '#bbf7d0' },
  rose: { bg: '#fff1f2', border: '#fecdd3' },
  emerald: { bg: '#ecfdf5', border: '#a7f3d0' },
};
---

<section class="section bg-subtle" id="features">
  <div class="container">
    <div class="section-header" data-animate>
      <div class="badge badge-orange">Fonctionnalités</div>
      <h2>Tout ce dont vous avez besoin pour cuisiner malin</h2>
      <p class="section-subtitle">
        DisChef combine intelligence artificielle et simplicité pour transformer votre quotidien en cuisine.
      </p>
    </div>

    <div class="features-grid">
      {features.map((feature, i) => (
        <div
          class="card feature-card"
          data-animate
          style={`animation-delay: ${i * 0.1}s; --card-bg: ${colorMap[feature.color].bg}; --card-border: ${colorMap[feature.color].border};`}
        >
          <div class="feature-icon">{feature.icon}</div>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 64px;
  }

  .section-header h2 {
    margin-top: 16px;
    margin-bottom: 16px;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--slate-500);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .feature-card {
    text-align: left;
    padding: 28px;
  }

  .feature-card:hover {
    border-color: var(--card-border);
    background: var(--card-bg);
  }

  .feature-icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    background: var(--card-bg);
    border-radius: 14px;
    margin-bottom: 16px;
  }

  .feature-card h3 {
    font-size: 1.125rem;
    margin-bottom: 8px;
    color: var(--slate-900);
  }

  .feature-card p {
    font-size: 0.9375rem;
    color: var(--slate-500);
    line-height: 1.6;
  }
</style>
