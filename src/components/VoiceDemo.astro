---

<section class="section voice-section" id="voice-demo">
  <div class="container">
    <div class="voice-inner" data-animate>
      <!-- Left: Visual demo -->
      <div class="voice-visual">
        <div class="voice-phone">
          <div class="voice-phone-screen">
            <!-- Conversation animée -->
            <div class="voice-conversation">
              <div class="vc-header">
                <div class="vc-mic-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" x2="12" y1="19" y2="22"/>
                  </svg>
                </div>
                <span class="vc-listening">Le Chef vous écoute...</span>
              </div>

              <!-- Waveform animation -->
              <div class="vc-waveform">
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
                <div class="wf-bar"></div>
              </div>

              <!-- Demo messages -->
              <div class="vc-messages">
                <div class="vc-msg vc-msg-user vc-anim-1">
                  <span>"Dis Chef, ajoute des tomates et du basilic dans mon frigo"</span>
                </div>
                <div class="vc-msg vc-msg-chef vc-anim-2">
                  <div class="vc-chef-dot"></div>
                  <span>C'est noté ! 2 ingrédients ajoutés à votre frigo.</span>
                </div>
                <div class="vc-msg vc-msg-user vc-anim-3">
                  <span>"Qu'est-ce qu'on mange ce soir ?"</span>
                </div>
                <div class="vc-msg vc-msg-chef vc-anim-4">
                  <div class="vc-chef-dot"></div>
                  <span>J'ai 3 idées ! Commençons par une caprese revisitée...</span>
                </div>
              </div>
            </div>

            <!-- Hands illustration -->
            <div class="vc-hands-badge">
              <span>🤲</span>
              <span class="vc-hands-text">Mains occupées ? Aucun souci.</span>
            </div>
          </div>
        </div>

        <!-- Glow effect -->
        <div class="voice-glow"></div>
      </div>

      <!-- Right: Content -->
      <div class="voice-content">
        <div class="badge badge-orange">La magie vocale</div>
        <h2>Dis Chef,<br /><span class="text-gradient">qu'est-ce qu'on mange ?</span></h2>
        <p class="voice-intro">
          Les mains dans la pâte, la tête ailleurs — parlez, Le Chef s'occupe de tout.
          Ajoutez des ingrédients, générez des recettes, planifiez votre semaine. Sans toucher l'écran.
        </p>

        <div class="voice-features">
          <div class="vf-item">
            <div class="vf-icon vf-icon-orange">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              </svg>
            </div>
            <div>
              <strong>Parlez naturellement</strong>
              <p>"Dis Chef, ajoute 3 œufs" — il comprend tout.</p>
            </div>
          </div>
          <div class="vf-item">
            <div class="vf-icon vf-icon-emerald">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21.2 8.4c.5.38.8.97.8 1.6v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 .8-1.6l8-6a2 2 0 0 1 2.4 0l8 6Z"/>
                <path d="m22 10-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 10"/>
              </svg>
            </div>
            <div>
              <strong>Le frigo se remplit tout seul</strong>
              <p>Dictez vos courses, Le Chef range dans votre frigo.</p>
            </div>
          </div>
          <div class="vf-item">
            <div class="vf-icon vf-icon-violet">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 8V4H8"/>
                <rect width="16" height="12" x="4" y="8" rx="2"/>
                <path d="M2 14h2"/>
                <path d="M20 14h2"/>
                <path d="M15 13v2"/>
                <path d="M9 13v2"/>
              </svg>
            </div>
            <div>
              <strong>Recettes pas-à-pas vocales</strong>
              <p>Le Chef vous guide pendant que vous cuisinez.</p>
            </div>
          </div>
        </div>

        <a href="https://apps.apple.com/app/dischef/id6739498942" class="btn btn-primary" target="_blank" rel="noopener">
          Essayer la voix
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .voice-section {
    background: linear-gradient(180deg, #ffffff 0%, var(--slate-50) 50%, #ffffff 100%);
    overflow: hidden;
  }

  .voice-inner {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 48px;
  }

  @media (min-width: 768px) {
    .voice-inner {
      flex-direction: row;
      gap: 80px;
    }
  }

  /* ---- Phone visual ---- */
  .voice-visual {
    position: relative;
    flex-shrink: 0;
  }

  .voice-phone {
    width: 280px;
    height: 500px;
    background: linear-gradient(145deg, #1a1a2e, #0f0f1a);
    border-radius: 40px;
    padding: 10px;
    box-shadow:
      0 40px 80px rgba(0, 0, 0, 0.15),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    position: relative;
    z-index: 2;
  }

  @media (min-width: 768px) {
    .voice-phone {
      width: 300px;
      height: 540px;
    }
  }

  .voice-phone-screen {
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, var(--frigo-500) 0%, var(--frigo-600) 30%, var(--slate-900) 30%);
    border-radius: 32px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Conversation */
  .voice-conversation {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 24px 16px 16px;
  }

  .vc-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .vc-mic-icon {
    width: 56px;
    height: 56px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: micGlow 2s ease-in-out infinite;
  }

  @keyframes micGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.3); }
    50% { box-shadow: 0 0 0 16px rgba(255, 255, 255, 0); }
  }

  .vc-listening {
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.02em;
  }

  /* Waveform */
  .vc-waveform {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    height: 32px;
    margin-bottom: 16px;
  }

  .wf-bar {
    width: 3px;
    height: 100%;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 3px;
    animation: waveformPulse 1.2s ease-in-out infinite;
  }

  .wf-bar:nth-child(1)  { animation-delay: 0s;    height: 40%; }
  .wf-bar:nth-child(2)  { animation-delay: 0.08s; height: 65%; }
  .wf-bar:nth-child(3)  { animation-delay: 0.16s; height: 45%; }
  .wf-bar:nth-child(4)  { animation-delay: 0.24s; height: 80%; }
  .wf-bar:nth-child(5)  { animation-delay: 0.32s; height: 55%; }
  .wf-bar:nth-child(6)  { animation-delay: 0.4s;  height: 90%; }
  .wf-bar:nth-child(7)  { animation-delay: 0.48s; height: 70%; }
  .wf-bar:nth-child(8)  { animation-delay: 0.56s; height: 100%; }
  .wf-bar:nth-child(9)  { animation-delay: 0.64s; height: 70%; }
  .wf-bar:nth-child(10) { animation-delay: 0.72s; height: 90%; }
  .wf-bar:nth-child(11) { animation-delay: 0.8s;  height: 55%; }
  .wf-bar:nth-child(12) { animation-delay: 0.88s; height: 80%; }
  .wf-bar:nth-child(13) { animation-delay: 0.96s; height: 45%; }
  .wf-bar:nth-child(14) { animation-delay: 1.04s; height: 65%; }
  .wf-bar:nth-child(15) { animation-delay: 1.12s; height: 40%; }
  .wf-bar:nth-child(16) { animation-delay: 1.2s;  height: 30%; }

  @keyframes waveformPulse {
    0%, 100% { transform: scaleY(0.4); opacity: 0.4; }
    50% { transform: scaleY(1); opacity: 1; }
  }

  /* Messages */
  .vc-messages {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow: hidden;
  }

  .vc-msg {
    padding: 10px 14px;
    border-radius: 16px;
    max-width: 92%;
    opacity: 0;
    animation: vcMsgIn 0.4s ease forwards;
  }

  .vc-msg span {
    font-size: 0.75rem;
    line-height: 1.4;
  }

  .vc-msg-user {
    background: rgba(255, 255, 255, 0.15);
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }

  .vc-msg-user span {
    color: rgba(255, 255, 255, 0.9);
    font-style: italic;
    font-weight: 500;
  }

  .vc-msg-chef {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }

  .vc-chef-dot {
    width: 8px;
    height: 8px;
    background: var(--frigo-400);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .vc-msg-chef span {
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
  }

  .vc-anim-1 { animation-delay: 0.8s; }
  .vc-anim-2 { animation-delay: 2s; }
  .vc-anim-3 { animation-delay: 3.5s; }
  .vc-anim-4 { animation-delay: 5s; }

  @keyframes vcMsgIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Hands badge */
  .vc-hands-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 0 0 32px 32px;
    padding: 12px 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .vc-hands-badge > span:first-child {
    font-size: 1.25rem;
  }

  .vc-hands-text {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
  }

  .voice-glow {
    position: absolute;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(249, 115, 22, 0.12), transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    pointer-events: none;
  }

  /* ---- Content ---- */
  .voice-content {
    flex: 1;
  }

  .voice-content h2 {
    margin-top: 16px;
    margin-bottom: 16px;
  }

  .voice-intro {
    margin-bottom: 32px;
    max-width: 520px;
  }

  .voice-features {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 36px;
  }

  .vf-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .vf-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .vf-icon-orange {
    background: var(--frigo-50);
    color: var(--frigo-500);
  }

  .vf-icon-emerald {
    background: #ecfdf5;
    color: #059669;
  }

  .vf-icon-violet {
    background: #f5f3ff;
    color: #7c3aed;
  }

  .vf-item strong {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--slate-900);
    margin-bottom: 2px;
  }

  .vf-item p {
    font-size: 0.9375rem;
    color: var(--slate-500);
    line-height: 1.5;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .wf-bar,
    .vc-mic-icon,
    .vc-msg {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
